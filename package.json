{
  "name": "claude-marketplace-browser",
  "version": "0.0.6",
  "description": "Browser web pour explorer les plugins d'un marketplace Claude",
  "main": "server.js",
  "bin": {
    "claude-marketplace-browser": "scripts/build.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i src/styles.css -o public/styles.css --minify",
    "watch:css": "tailwindcss -i src/styles.css -o public/styles.css --watch",
    "build": "npm run build:css && node scripts/build.js"
  },
  "files": [
    "scripts/",
    "lib/",
    "public/",
    "src/",
    "tailwind.config.js",
    "browser.config.js"
  ],
  "dependencies": {
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
